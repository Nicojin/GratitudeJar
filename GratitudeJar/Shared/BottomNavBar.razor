@using Microsoft.JSInterop
@inject NavigationManager NavManager

<nav class="bottom-nav">
    <button class="nav-item @(IsActive("") ? "active" : "")" @onclick='() => Navigate("")'>
        <span class="nav-icon">🏠</span>
        <span>Jar</span>
    </button>
    <button class="nav-item @(IsActive("browse") ? "active" : "")" @onclick='() => Navigate("browse")'>
        <span class="nav-icon">📖</span>
        <span>Browse</span>
    </button>
    
    <button class="nav-item add-fab" @onclick="OpenAddEntry" style="transform: translateY(-15px); background: var(--sage); border-radius: 50%; width: 56px; height: 56px; color: white;">
        <span class="nav-icon" style="font-size: 2rem;">+</span>
    </button>
    
    <button class="nav-item @(IsActive("shake") ? "active" : "")" @onclick='() => Navigate("shake")'>
        <span class="nav-icon">✨</span>
        <span>Shake</span>
    </button>
    <button class="nav-item @(IsActive("insights") ? "active" : "")" @onclick='() => Navigate("insights")'>
        <span class="nav-icon">📊</span>
        <span>Insights</span>
    </button>
</nav>

@code {
    private bool IsActive(string route)
    {
        var current = NavManager.ToBaseRelativePath(NavManager.Uri).ToLower();
        return current == route.ToLower();
    }

    private void Navigate(string route)
    {
        // Trigger haptics
        _ = JSRuntime.InvokeVoidAsync("gratitudeMobile.triggerHaptic", "tap");
        NavManager.NavigateTo($"/{route}");
    }

    [Inject] IJSRuntime JSRuntime { get; set; } = default!;

    private void OpenAddEntry()
    {
        _ = JSRuntime.InvokeVoidAsync("gratitudeMobile.triggerHaptic", "tap");
        // In a real app, this would fire an EventCallback or use a state container
        // to tell the MainLayout to pop open the <BottomSheet> component.
    }
}