@page "/entries"
@using GratitudeJar.Models
@using GratitudeJar.Data
@inject IEntryRepository Database
@inject NavigationManager Navigation

<div class="entries-dashboard">
    
    <div class="actions-grid" style="display: flex; gap: 15px; margin-bottom: 30px;">
        <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/add-entry")'>
            + Add New Entry
        </button>
        <button class="btn-secondary" @onclick='() => Navigation.NavigateTo("/all-entries")'>
            View All Entries
        </button>
    </div>

    <div class="card">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
            <h3 style="margin: 0;">Recently Added</h3>
        </div>
        
        @if (recentEntries.Count == 0)
        {
            <p style="color: var(--text-muted); padding: 20px 0; text-align: center;">No entries yet. Add your first entry!</p>
        }
        else
        {
            @foreach (var entry in recentEntries)
            {
                <div style="padding: 15px; border-bottom: 1px solid #EAE3DC; display:flex; justify-content: space-between;">
                    <div>
                        <strong style="display:block; color: var(--text-main);">@entry.Summarize()</strong>
                        <span style="font-size: 0.8rem; color: var(--text-muted);">@entry.GetType().Name.Replace("Entry", "") • @entry.Date.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div style="color: var(--accent-warm); cursor: pointer;" @onclick='() => Navigation.NavigateTo($"/edit-entry/{entry.EntryId}")'>✏️</div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<Entry> recentEntries = new();

    protected override void OnInitialized()
    {
        LoadEntries();
    }

    private void LoadEntries()
    {
        var all = Database.GetAllEntries();
        recentEntries = all.OrderByDescending(e => e.Date).Take(5).ToList();
    }
}