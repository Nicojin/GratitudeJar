@page "/jar"
@using GratitudeJar.Models
@using GratitudeJar.Data
@inject IEntryRepository Database

<div class="jar-page-container">
    
    <div class="jar-wrapper">
        <button class="btn-shake" @onclick="ShakeJar">SHAKE JAR</button>
        
        <div class="the-jar @(isShaking ? "shake-anim" : "")" @onclick="ShakeJar">
            <div class="jar-lid"></div>
            <div class="jar-glass">
                <div class="paper-note note-1"></div>
                <div class="paper-note note-2"></div>
                <div class="paper-note note-3"></div>
            </div>
        </div>
    </div>

    <div class="progress-section">
        <div class="progress-bar-container">
            <div class="progress-fill" style="width: @fillPercentage%;"></div>
        </div>
        <p class="upgrade-text">@upgradeMessage</p>
    </div>
</div>

@if (randomEntry != null)
{
    <div class="random-entry-modal">
        <div class="modal-content">
            <h3>Random Memory</h3>
            <p>@randomEntry.Summarize()</p>
            <button @onclick="CloseRandom" class="btn-close">Close</button>
        </div>
    </div>
}

@code {
    private int totalEntries = 0;
    private int entryLimit = 30;
    private bool isShaking = false;
    private Entry? randomEntry = null;
    private string fillPercentage => totalEntries == 0 ? "5%" : $"{Math.Min((double)totalEntries / entryLimit * 100, 100)}%";
    private string upgradeMessage => totalEntries >= entryLimit ? "Jar full! Upgrade your jar" : $"{entryLimit - totalEntries} more to upgrade";

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        totalEntries = Database.GetEntryCount();
        var upgrade = new JarUpgrade();
        upgrade.ApplyUpgrade(totalEntries);
        entryLimit = upgrade.EntryLimit;
        StateHasChanged();
    }

    private async Task ShakeJar()
    {
        if (isShaking) return;
        
        isShaking = true;
        StateHasChanged();
        await Task.Delay(400);
        isShaking = false;
        
        randomEntry = Database.GetRandomEntry();
        StateHasChanged();
        
        await Task.Delay(3000);
        randomEntry = null;
        StateHasChanged();
    }

    private void CloseRandom()
    {
        randomEntry = null;
    }
}