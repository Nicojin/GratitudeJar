@page "/"
@using GratitudeJar.Models
@using GratitudeJar.Data
@inject IEntryRepository Database

<div class="welcome-header" style="margin-bottom: 20px;">
    <h2>Welcome!</h2>
    <p style="color: var(--text-muted);">Ready to reflect today?</p>
</div>

<div class="card streak-card" style="text-align: center;">
    <h3 style="color: var(--text-muted); font-size: 1rem; margin-bottom: 5px;">STREAK</h3>
    <div style="font-size: 2.5rem; font-weight: bold; color: var(--accent-warm);">5 Days</div>
</div>

<div class="card mood-card">
    <h3>MOOD BOARD</h3>
    <p style="color: var(--text-muted); padding: 20px 0; text-align: center;">
        Mood tracking coming soon!
    </p>
</div>