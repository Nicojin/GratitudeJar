@page "/all-entries"
@using GratitudeJar.Models
@using GratitudeJar.Data
@inject IEntryRepository Database
@inject NavigationManager Navigation

<div style="display: flex; align-items: center; margin-bottom: 20px;">
    <button style="background: none; border: none; font-size: 1.5rem; cursor: pointer;" @onclick='() => Navigation.NavigateTo("/entries")'>←</button>
    <h2 style="margin: 0 0 0 10px;">All Entries</h2>
</div>

<div class="card list-card">
    @if (allEntries.Count == 0)
    {
        <p style="color: var(--text-muted); padding: 40px; text-align: center;">No entries yet. Add your first entry!</p>
    }
    else
    {
        @foreach (var entry in allEntries)
        {
            <div class="entry-list-item">
                <div class="entry-info">
                    <strong>@entry.Summarize()</strong>
                    <span>@entry.GetType().Name.Replace("Entry", "") • @entry.Date.ToString("MMM dd, yyyy")</span>
                    <span style="font-size: 0.7rem; color: var(--text-muted);">Mood: @entry.MoodTag</span>
                </div>
                <div class="entry-actions">
                    <button class="action-btn edit-btn" @onclick='() => EditEntry(entry.EntryId)'>✏️</button>
                    <button class="action-btn delete-btn" @onclick='() => DeleteEntry(entry.EntryId)'>🗑️</button>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Entry> allEntries = new();

    protected override void OnInitialized()
    {
        LoadEntries();
    }

    private void LoadEntries()
    {
        allEntries = Database.GetAllEntries().OrderByDescending(e => e.Date).ToList();
        StateHasChanged();
    }

    private void DeleteEntry(int id)
    {
        Database.DeleteEntry(id);
        LoadEntries();
    }

    private void EditEntry(int id)
    {
        Navigation.NavigateTo($"/edit-entry/{id}");
    }
}

<style>
    .entry-list-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 0;
        border-bottom: 1px solid #EAE3DC;
    }
    .entry-list-item:last-child { border-bottom: none; }
    
    .entry-info strong { display: block; color: var(--text-main); }
    .entry-info span { font-size: 0.8rem; color: var(--text-muted); display: block; margin-top: 4px; }
    
    .action-btn {
        background: none;
        border: none;
        font-size: 1.2rem;
        cursor: pointer;
        padding: 5px;
    }
    .edit-btn { color: var(--accent-warm); }
    .delete-btn { color: #d32f2f; }
</style>