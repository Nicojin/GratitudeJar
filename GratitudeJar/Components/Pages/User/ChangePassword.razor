@page "/user/password"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthService AuthService
@inject UserService UserService
@inject NavigationManager Nav

<PageTitle>GratitudeJar — Change Password</PageTitle>

<AppHeader Subtitle="A Glimpse of You" />

<div class="main-content">
    <div class="jar-header-section"></div>

    <div class="page-body">
        <div class="back-row">
            <button class="back-btn" @onclick='() => Nav.NavigateTo("/user")'>&#8249;</button>
            <h2>Change Password</h2>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <div class="entry-form">
            <div>
                <label class="form-label-plain">Current Password</label>
                <input type="password" class="form-input" placeholder="Enter current password" @bind="currentPassword" />
            </div>

            <div>
                <label class="form-label-plain">New Password</label>
                <input type="password" class="form-input" placeholder="Enter new password" @bind="newPassword" />
            </div>

            <div>
                <label class="form-label-plain">Confirm New Password</label>
                <input type="password" class="form-input" placeholder="Confirm new password" @bind="confirmPassword" />
            </div>

            <div class="security-tip-card">
                <div class="security-tip-icon">&#128737;</div>
                <div class="security-tip-text">
                    <strong>Security Tip</strong>
                    Use a strong, unique password and avoid reusing passwords from other sites to keep your account secure.
                </div>
            </div>

            <div class="form-actions">
                <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/user")'>Cancel</button>
                <button class="btn btn-primary" @onclick="SavePassword" disabled="@isSaving">
                    @(isSaving ? "Saving…" : "✓ Save Changes")
                </button>
            </div>
        </div>
    </div>
</div>

<BottomNav />

@code {
    private GratitudeJar.Models.User? currentUser;
    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
    }

    private async Task SavePassword()
    {
        if (currentUser is null) return;
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword))
        {
            errorMessage = "All fields are required.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "New passwords do not match.";
            return;
        }

        isSaving = true;
        var (success, error) = await UserService.ChangePasswordAsync(currentUser.Id, currentPassword, newPassword);
        if (success)
        {
            successMessage = "Password changed successfully!";
            currentPassword = newPassword = confirmPassword = string.Empty;
        }
        else
            errorMessage = error;

        isSaving = false;
    }
}
